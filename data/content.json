    "sections": [
        {
            "id": "gestion-conocimiento",
            "title": "Gestión del Conocimiento",
            "definition": "Es el proceso sistemático e institucionalizado de identificar, capturar, organizar, compartir y aplicar el conocimiento tácito (experiencia) y explícito (documentos) de los servidores públicos, transformándolo en un activo estratégico para la entidad.",
            "purpose": "Evitar la pérdida del \"saber hacer\" (fuga de capital intelectual) ante la rotación de personal, facilitar la toma de decisiones basada en evidencia, reducir la curva de aprendizaje de los nuevos colaboradores y fomentar una cultura de mejora continua.",
            "phases": [
                { "title": "Identificación", "description": "Mapeo del conocimiento crítico necesario para los procesos clave.", "icon": "search" },
                { "title": "Captura y Creación", "description": "Sistematización de buenas prácticas y lecciones aprendidas.", "icon": "pen-tool" },
                { "title": "Organización y Almacenamiento", "description": "Creación de repositorios institucionales accesibles.", "icon": "database" },
                { "title": "Transferencia y Difusión", "description": "Comunidades de práctica, mentorías y capacitaciones internas.", "icon": "share-2" }
            ],
            "roles": [
                { "role": "Alta Dirección", "description": "Patrocina y aprueba las políticas de conocimiento." },
                { "role": "Comité de Gestión", "description": "Diseña y monitorea la estrategia institucional." },
                { "role": "Expertos Temáticos", "description": "Generan y validan el conocimiento clave del programa." },
                { "role": "Servidores Públicos", "description": "Usuarios activos que aplican y retroalimentan el sistema." }
            ],
            "video_url": "#",
            "video_title": "Resumen Ejecutivo: Gestión del Conocimiento"
        },
        {
            "id": "gestion-procesos",
            "title": "Gestión por Procesos",
            "definition": "Forma de gestión de la entidad pública que orienta sus procesos a la creación de valor público, para lo cual los organiza en procesos estratégicos, operativos y de soporte.",
            "purpose": "Mejorar la eficiencia y eficacia de la gestión pública mediante el análisis continuo de las actividades que transforman insumos en resultados.",
            "phases": [
                { "title": "Determinación de Procesos", "description": "Identificar los procesos clave de la entidad.", "icon": "map" },
                { "title": "Seguimiento y Evaluación", "description": "Medición del desempeño de los procesos.", "icon": "activity" },
                { "title": "Mejora de Procesos", "description": "Optimización constante para generar mayor valor.", "icon": "trending-up" }
            ],
            "roles": [
                { "role": "Dueño del Proceso", "description": "Responsable de la ejecución y mejora del proceso." },
                { "role": "Equipo Operativo", "description": "Ejecuta las actividades diarias del proceso." }
            ],
            "video_url": "#",
            "video_title": "Tutorial: Gestión por Procesos"
        },
        {
            "id": "innovacion-publica",
            "title": "Innovación Pública",
            "definition": "Proceso iterativo mediante el cual se crean nuevas soluciones a problemas públicos, involucrando a diversos actores para generar valor público.",
            "purpose": "Modernizar la gestión estatal mediante soluciones creativas, inclusivas y escalables.",
            "phases": [
                { "title": "Ideación", "description": "Generación de ideas disruptivas para mejorar el servicio.", "icon": "lightbulb" },
                { "title": "Prototipado", "description": "Desarrollo de versiones preliminares para prueba.", "icon": "cpu" }
            ],
            "roles": [
                { "role": "Innovadores", "description": "Servidores que proponen y lideran proyectos." }
            ],
